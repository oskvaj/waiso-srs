// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

model Teacher {
    userId String @id
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    //Courses they have created
    courses Course[]
}

model Student {
    userId String @id
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    //Courses they attend
    inCourses StudentInCourse[]
}

model Course {
    id          String  @id @default(cuid())
    name        String
    description String?
    published   Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    teacherId String

    teacher Teacher @relation(fields: [teacherId], references: [userId]) //If indtended behaviour is delete courses when teacher is deleted, add ", onDelete: Cascade"

    //Modules that are part of the course
    modules          Module[]
    //Students that are in the course
    studentInCourses StudentInCourse[]

    @@index([teacherId])
}

model Module {
    id      String @id @default(cuid())
    name    String
    content Json
    level   Int    @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    prerequisites Module[] @relation("ModulePrerequisite")
    requiredFor   Module[] @relation("ModulePrerequisite")

    courseId String
    course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

    //What questions belong to this module
    questions        Question[]
    moduleProgresses ModuleProgress[]

    @@index([courseId])
}

enum QuestionType {
    MULTIPLE_CHOICE
    FREE_TEXT
    PAIR
}

model Question {
    id      String       @id @default(cuid())
    name    String
    type    QuestionType
    content Json

    correctAnswers Int @default(0) //Times a student got question correct
    totalAnswers   Int @default(0) //Times a student has answered the question

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    moduleId String

    module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

    @@index([moduleId])
}

model StudentInCourse {
    studentId String
    courseId  String

    createdAt DateTime @default(now())

    student Student @relation(fields: [studentId], references: [userId], onDelete: Cascade)
    course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

    ModuleProgress ModuleProgress[]

    @@id([studentId, courseId])
    @@index([courseId])
}

model ModuleProgress {
    studentId     String
    courseId      String
    moduleId      String
    level         Int       @default(0)
    nextReview    DateTime? //Next FULL HOUR when a review is scheduled, NULL if user has review active but has not done it
    hasReadTheory Boolean   @default(false)

    enrollment StudentInCourse @relation(fields: [studentId, courseId], references: [studentId, courseId])
    module     Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)

    @@id([studentId, courseId, moduleId])
    @@index([nextReview])
    @@index([studentId, nextReview])
}

model PushSubscription {
    id       String @id @default(cuid())
    userId   String
    endpoint String @unique
    p256dh   String
    auth     String

    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    createdAt     DateTime  @default(now())
    image         String?

    accounts Account[]
    sessions Session[]

    teacher           Teacher?
    student           Student?
    pushSubscriptions PushSubscription[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
